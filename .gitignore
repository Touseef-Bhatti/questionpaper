# ------------------------------
# 🔒 Project .gitignore — Keep sensitive & system files out of Git
# ------------------------------

# 🧩 Environment files (never commit real creds)
.env
.env.*
!config/.env.template
!config/.env.example

env.php

# 🗄️ Databases / Dumps
*.sql
*.sqlite
*.db
dump/
backup/

# 📦 Dependencies
node_modules/
vendor/

# 🧠 Build / Dist outputs
dist/
build/
.cache/
.tmp/
coverage/

# 📂 Cache files (AI MCQs, questions, topics)
/cache/*
!/cache/.gitkeep



# 🖥️ IDE & Editor settings
.vscode/
.idea/
*.swp

# 🧱 OS-specific junk
.DS_Store
Thumbs.db

# 🔍 Logs & temp files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# 📤 Uploads & User files
/uploads/*
!/uploads/.gitkeep
/logs/*
!/logs/.gitkeep

# 🧰 Miscellaneous
ads.php
.env.local
.env.development.local
.env.production.local
.env.test.local
