# Environment Configuration Template
# Copy this file to .env and fill in your actual server details

# STEP 1: Application Settings
APP_ENV=production
APP_NAME=Ahmad Learning Hub
APP_URL=https://paper.bhattichemicalsindustry.com.pk

# STEP 2: Database Configuration
# Get these from your cPanel → MySQL Databases section
DB_HOST=localhost
DB_USER=bhattich_your_username
DB_PASSWORD=your_database_password
DB_NAME=bhattich_your_database_name

# STEP 3: Email Configuration
# Get these from your cPanel → Email Accounts section
SMTP_HOST=mail.bhattichemicalsindustry.com.pk
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=paper@bhattichemicalsindustry.com.pk
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=paper@bhattichemicalsindustry.com.pk
SMTP_FROM_NAME=Ahmad Learning Hub
SMTP_AUTH=true
SMTP_DEBUG=0

# STEP 4: Security Settings (optional - defaults are fine)
SESSION_TIMEOUT=3600
REGISTRATION_TIMEOUT=86400
PHP_TIMEOUT=60
MEMORY_LIMIT=128M

# STEP 5: AI Configuration
# Key for generating topic keywords only (NVIDIA API Key)
GENERATING_KEYWORDS_KEY=nvapi-your-key-here

# MCQ verification / recheck. If unset, GENERATING_KEYWORDS_KEY is used as fallback.
# nvapi-... keys → NVIDIA integrate.api.nvidia.com (same stack as keywords). OpenRouter keys → openrouter.ai.
RECHECK_API_KEY=
# Optional. If empty: OpenRouter keys use AI_DEFAULT_MODEL
RECHECK_MODEL=

# AI Defaults (Set these!)
AI_DEFAULT_MODEL=
AI_FALLBACK_MODEL=

# Google Gemini — file upload → MCQs / question paper (generate_from_upload.php)
# Create a key in Google AI Studio; model default is gemini-2.5-flash if GEMINIMODEL is empty.
GEMINIAPIKEY=
GEMINIMODEL=gemini-2.5-flash
# Optional: separate key for post-upload verification (explanations, answer refinement). Falls back to GEMINIAPIKEY if empty.
GEMINIAPIKEYFORRECHECK=
# Optional model for recheck; defaults to GEMINIMODEL when empty.
GEMINIRECHECKMODEL=
# If cURL SSL certificate verification fails on your host, set to false (less secure).
GEMINI_SSL_VERIFY=true
# Shared hosting: allow uploads up to 10 MB in this app — raise PHP limits if needed:
# In .user.ini or php.ini set upload_max_filesize=12M and post_max_size=12M (and max_execution_time for large PDFs).

