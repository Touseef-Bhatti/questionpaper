# Force PHP 8.1 for this subdomain
AddHandler application/x-httpd-ea-php81 .php

# Default index file
DirectoryIndex index.php

# Disable directory browsing
Options -Indexes

# Protect .env files (any variant) in this directory
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

# Block access to common backup/archive files
<FilesMatch "\.(bak|sql|tar|gz|zip)$">
    Require all denied
</FilesMatch>

# SEO-Optimized URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Specific SEO rule for quiz_setup.php
    RewriteCond %{THE_REQUEST} /quiz/quiz_setup\.php [NC,OR]
    RewriteCond %{THE_REQUEST} /quiz_setup [NC]
    RewriteRule ^(quiz/)?quiz_setup(\.php)?$ /online-mcqs-test-for-9th-and-10th-board-exams [R=301,L]
    RewriteRule ^online-mcqs-test-for-9th-and-10th-board-exams/?$ quiz/quiz_setup.php [NC,L]

    # Specific SEO rule for mcqs_topic.php
    RewriteCond %{THE_REQUEST} /quiz/mcqs_topic\.php [NC,OR]
    RewriteCond %{THE_REQUEST} /mcqs_topic [NC]
    RewriteRule ^(quiz/)?mcqs_topic(\.php)?$ /topic-wise-mcqs-test [R=301,L]
    RewriteRule ^topic-wise-mcqs-test/?$ quiz/mcqs_topic.php [NC,L]

    # 1. Map root-level requests to 'quiz/' folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/quiz/$1.php -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/quiz/$1 -f
    RewriteRule ^([^/]+)$ quiz/$1 [L]

    # 2. Map root-level requests to 'questionPaperFromTopic/' folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/questionPaperFromTopic/$1.php -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/questionPaperFromTopic/$1 -f
    RewriteRule ^([^/]+)$ questionPaperFromTopic/$1 [L]

    # 3. Map root-level requests to 'notes/' folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/notes/$1.php -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/notes/$1 -f
    RewriteRule ^([^/]+)$ notes/$1 [L]

    # 4. Map root-level requests to 'auth/' folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/auth/$1.php -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/auth/$1 -f
    RewriteRule ^([^/]+)$ auth/$1 [L]

    # 5. Handle SEO pattern for class/book question paper generator
    # Matches patterns like: 10th-class-physics-chapter-1-2-mcqs-12-short-24-long-3-question-paper-generator
    RewriteRule ^([0-9]+)(?:st|nd|rd|th)-class-([a-zA-Z0-9-]+)-(?:chapter-([a-zA-Z0-9,%\s\-]+)-)?mcqs-([0-9]+)-short-([0-9]+)-long-([0-9]+)-question-paper-generator/?$ generate_question_paper.php?class_id=$1&book_name=$2&chapters_from_url=$3&total_mcqs=$4&total_shorts=$5&total_longs=$6 [QSA,NC,L]

    # Matches patterns like: 10th-class-physics-question-paper-generator
    RewriteRule ^([0-9]+)(?:st|nd|rd|th)-class-([a-zA-Z0-9-]+)-question-paper-generator/?$ select_chapters.php?class_id=$1&book_name=$2 [QSA,NC,L]

    # Matches patterns like: 10th-class-physics-chapter-1-2-question-paper-generator or 10th-class-physics-all-chapter-question-paper-generator
    # These point to question selection
    RewriteRule ^([0-9]+)(?:st|nd|rd|th)-class-([a-zA-Z0-9-]+)-chapter-([a-zA-Z0-9,%\s\-]+)-question-paper-generator/?$ select_question.php?class_id=$1&book_name=$2&chapters_from_url=$3 [QSA,NC,L]
    RewriteRule ^([0-9]+)(?:st|nd|rd|th)-class-([a-zA-Z0-9-]+)-all-chapter-question-paper-generator/?$ select_question.php?class_id=$1&book_name=$2&chapters_from_url=all [QSA,NC,L]

    # Specific SEO rule for select_class.php
    RewriteRule ^class-9th-and-10th-online-question-paper-generator/?$ select_class.php [NC,L]

    # Specific SEO rule for select_book.php (per class)
    RewriteRule ^class-([0-9]+)-online-question-paper-generator/?$ select_book.php?class_id=$1 [QSA,NC,L]

    # Specific SEO rule for AI Topic Paper Generator (questionPaperFromTopic/home.php)
    RewriteCond %{THE_REQUEST} /questionPaperFromTopic/home\.php [NC]
    RewriteRule ^questionPaperFromTopic/home\.php$ /online-question-paper-generator [R=301,L]
    RewriteRule ^online-question-paper-generator/?$ questionPaperFromTopic/home.php [NC,L]

    # Specific SEO rules for AI Topic Paper Finalizer (questionPaperFromTopic/finalize_paper.php)
    RewriteRule ^online-mcqs-question-paper-generator/?$ questionPaperFromTopic/finalize_paper.php [NC,L]
    RewriteRule ^online-short-question-paper-generator/?$ questionPaperFromTopic/finalize_paper.php [NC,L]
    RewriteRule ^online-long-question-paper-generator/?$ questionPaperFromTopic/finalize_paper.php [NC,L]
    RewriteRule ^online-mcqs-short-and-long-question-paper-generator/?$ questionPaperFromTopic/finalize_paper.php [NC,L]

    # 6. Handle SEO pattern for MCQs page
    # Matches patterns like: mcqs/9th-class/physics
    RewriteRule ^mcqs/([0-9]+)(?:st|nd|rd|th)-class/([a-zA-Z0-9-]+)/?$ notes/mcqs.php?class_id=$1&book_name=$2&view=1 [QSA,NC,L]

    # 4. Hide .php extensions for a cleaner URL structure (General Root Files)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [NC,L]
</IfModule>
